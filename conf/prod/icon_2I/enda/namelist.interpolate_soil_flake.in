&interpolate
  file_s     = '@SMA_WORKDIR@/sma_@DATE@@TIME@.grib' ! input GRIB file name
  file_d     = '@SMA_WORKDIR@/data/sma_@DATE@@TIME@.grib' ! output GRIB file name
  ifile_s    = '@WORKDIR_BASE_OPE@/data/icon/icon_eu_dwd_foricon/icon_extpar_icon_eu_dwd_foricon_reduced.g2' ! invariant file (source)
  ifile_d    = '@MODEL_STATIC@/domain_@DOMAIN@/external_parameter_icon_ICON_REG3_DOM01_tiles_reduced.g2' ! invariant file (output) documentare come fare _reduced
  gfile_s    = '@WORKDIR_BASE_OPE@/data/icon/icon_eu_dwd_foricon/icon_eu_dwd_foricon_extended.nc' ! grid-file (source)
  gfile_d    = '@LOCALGRID@' ! grid-file (output)
  grid_d     = 'icon'                 ! destination grid (icon, gme, latlon)
  var        = 'W_SO T_SO'                ! variables to interpolate
  var_inc    = ''            ! variables to interpolate as increments
  l_ana      = .true.                 ! write result as analysis
  fr_lake = 0.5 0.5 ! lower bound for fr_lake (source, destination)
!  gpi        = 11                  ! generatingProcessIdentifier
!  bp         = 2                      ! backgroundProcess
/

